{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gradle: classes",
      "type": "shell",
      "command": "./gradlew classes",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "gradle: bootRunDebug",
      "type": "shell",
      "command": "bash -lc 'if docker ps --filter \"name=kotlin_training_postgres\" --filter \"status=running\" --format \"{{.Names}}\" | grep -q kotlin_training_postgres; then echo \"PostgreSQL already running\"; elif docker ps -a --filter \"name=kotlin_training_postgres\" --format \"{{.Names}}\" | grep -q kotlin_training_postgres; then echo \"Starting existing PostgreSQL container\"; docker start kotlin_training_postgres >/dev/null; else echo \"Creating PostgreSQL container\"; docker run -d --name kotlin_training_postgres -p 5432:5432 -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=medical_data postgres:15 >/dev/null; fi; ./gradlew bootRunDebug'",
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting.*$",
          "endsPattern": "^.*Started.*in.*seconds.*$"
        }
      }
    },
    {
      "label": "gradle: unitTestDebug",
      "type": "shell",
      "command": "./gradlew unitTest --no-daemon -Dorg.gradle.jvmargs=\"-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=*:5006\"",
      "isBackground": true,
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Listening for transport dt_socket.*$",
          "endsPattern": "^.*BUILD (SUCCESSFUL|FAILED).*$"
        }
      }
    },
    {
      "label": "gradle: integrationTestDebug",
      "type": "shell",
      "command": "./gradlew integrationTest --no-daemon -Dorg.gradle.jvmargs=\"-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=*:5007\"",
      "isBackground": true,
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Listening for transport dt_socket.*$",
          "endsPattern": "^.*BUILD (SUCCESSFUL|FAILED).*$"
        }
      }
    },
    {
      "label": "gradle: coverage (unit tests)",
      "type": "shell",
      "command": "./gradlew unitTest jacocoUnitTestReport",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "gradle: coverage (integration tests)",
      "type": "shell",
      "command": "./gradlew integrationTest jacocoIntegrationTestReport",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "gradle: coverage (combined)",
      "type": "shell",
      "command": "./gradlew jacocoCombinedReport",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "coverage: open unit test report",
      "type": "shell",
      "command": "xdg-open build/reports/jacoco/unitTest/html/index.html 2>/dev/null || open build/reports/jacoco/unitTest/html/index.html 2>/dev/null || start build/reports/jacoco/unitTest/html/index.html",
      "group": "test",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "coverage: open combined report",
      "type": "shell",
      "command": "xdg-open build/reports/jacoco/combined/html/index.html 2>/dev/null || open build/reports/jacoco/combined/html/index.html 2>/dev/null || start build/reports/jacoco/combined/html/index.html",
      "group": "test",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "gradle: ktlintCheck",
      "detail": "Check all Kotlin sources for style violations (read-only, fails on violations).",
      "type": "shell",
      "command": "./gradlew ktlintCheck",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        {
          "owner": "ktlint",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": {
            "regexp": "^(.+):(\\d+):(\\d+): (\\w+): (.+)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
          }
        }
      ]
    },
    {
      "label": "gradle: ktlintFormat",
      "detail": "Auto-format all Kotlin sources to comply with ktlint rules.",
      "type": "shell",
      "command": "./gradlew ktlintFormat",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
